                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tourist@exploreceylon.lk\",\n  \"password\": \"tourist123\"\n}",
